POSTGRES_DB=bravoclient
POSTGRES_USER=bravoclient
POSTGRES_PASSWORD=replace_with_a_long_random_password

APP_DOMAIN=cp.bravoclient.co
APP_URL=https://cp.bravoclient.co
WEBHOOK_DOMAIN=hooks.bravoclient.co
BASIC_AUTH_USER=bravoclient
BASIC_AUTH_PASSWORD=replace_with_a_long_random_password

DIRECTUS_DOMAIN=dt.bravoclient.co
DIRECTUS_PUBLIC_URL=https://dt.bravoclient.co
DIRECTUS_KEY=replace_with_32_plus_random_chars
DIRECTUS_SECRET=replace_with_32_plus_random_chars
DIRECTUS_ADMIN_EMAIL=admin@bravoclient.co
DIRECTUS_ADMIN_PASSWORD=replace_with_a_long_random_password

# Common Traefik resolver names are letsencrypt, le, myresolver or production.
# Keep this aligned with Hostinger's Docker and Traefik template.
TRAEFIK_CERT_RESOLVER=letsencrypt

STRIPE_SECRET_KEY=sk_live_or_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

CLIMBO_API_BASE_URL=https://api.climbo.example
CLIMBO_API_KEY=replace_me
